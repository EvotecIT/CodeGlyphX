powerforge-codeglyphx ALL=(root) NOPASSWD: /usr/local/sbin/powerforge-site-deploy ^--site codeglyphx\.com --archive /tmp/powerforge-[0-9]+-[0-9]+-codeglyphx\.com/artifact\.tar --metadata /tmp/powerforge-[0-9]+-[0-9]+-codeglyphx\.com/deployment\.json --defer-public-verification$
powerforge-codeglyphx ALL=(root) NOPASSWD: /usr/local/sbin/powerforge-site-deploy ^--site codeglyphx\.com --finalize --release-id [A-Za-z0-9][A-Za-z0-9._-]*$
powerforge-codeglyphx ALL=(root) NOPASSWD: /usr/local/sbin/powerforge-site-deploy ^--site codeglyphx\.com --rollback --release-id [A-Za-z0-9][A-Za-z0-9._-]*$
