{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/161a22a7a91b6f05b7bf9268287ff69f44ea204a/Schemas/powerforge.web.serverrecovery.schema.json",
  "schemaVersion": 2,
  "name": "codeglyphx-production-ovh",
  "description": "Recovery manifest for the CodeGlyphX static website.",
  "target": {
    "sshAlias": "evotec-ovh",
    "user": "ubuntu",
    "sshPort": 22222,
    "os": "ubuntu-24.04",
    "architecture": "x64"
  },
  "repositories": [
    {
      "role": "application-and-website",
      "url": "https://github.com/EvotecIT/CodeGlyphX.git",
      "path": "/srv/evotec/CodeGlyphX",
      "branch": "master",
      "ref": "b7b717fec0052b16bacff015e33c6945617ed8d5",
      "refCaptureCommandId": "static-source-ref",
      "required": true
    },
    {
      "role": "recovery-configuration",
      "url": "https://github.com/EvotecIT/CodeGlyphX.git",
      "path": "/srv/evotec/CodeGlyphXRecovery",
      "branch": "master",
      "ref": "0410ddab72d4cf346b725402d59f57d200b4be62",
      "required": true
    },
    {
      "role": "deployment-engine",
      "url": "https://github.com/EvotecIT/PSPublishModule.git",
      "path": "/srv/evotec/PSPublishModule",
      "branch": "main",
      "ref": "161a22a7a91b6f05b7bf9268287ff69f44ea204a",
      "required": true
    }
  ],
  "accounts": [
    {
      "name": "powerforge-codeglyphx",
      "system": false,
      "createHome": true,
      "home": "/home/powerforge-codeglyphx",
      "shell": "/bin/bash"
    },
    {
      "name": "powerforge-codeglyphx-backup",
      "system": true,
      "createHome": true,
      "home": "/var/lib/powerforge-codeglyphx-backup",
      "shell": "/bin/bash"
    }
  ],
  "packages": {
    "apt": [
      "age",
      "apache2",
      "certbot",
      "curl",
      "git",
      "jq",
      "logrotate",
      "python3",
      "python3-certbot-apache",
      "rsync",
      "ufw",
      "xz-utils"
    ],
    "apacheModules": [
      "headers",
      "remoteip",
      "rewrite",
      "setenvif",
      "ssl"
    ],
    "powershell": false
  },
  "paths": [
    {
      "id": "static-releases",
      "path": "/var/www/codeglyphx/com/releases",
      "kind": "directory",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "static-current",
      "path": "/var/www/codeglyphx/com/current",
      "kind": "symlink",
      "owner": "root",
      "group": "root"
    },
    {
      "id": "deployment-user-home",
      "path": "/home/powerforge-codeglyphx",
      "kind": "directory",
      "owner": "powerforge-codeglyphx",
      "group": "powerforge-codeglyphx",
      "mode": "750"
    },
    {
      "id": "deployment-user-ssh",
      "path": "/home/powerforge-codeglyphx/.ssh",
      "kind": "directory",
      "owner": "powerforge-codeglyphx",
      "group": "powerforge-codeglyphx",
      "mode": "700"
    },
    {
      "id": "deployment-user-authorized-keys",
      "path": "/home/powerforge-codeglyphx/.ssh/authorized_keys",
      "source": "/srv/evotec/CodeGlyphX/deploy/linux/powerforge-codeglyphx-authorized_keys",
      "kind": "file",
      "owner": "powerforge-codeglyphx",
      "group": "powerforge-codeglyphx",
      "mode": "600"
    },
    {
      "id": "cloudflare-origin-state",
      "path": "/var/lib/powerforge/cloudflare-origin",
      "kind": "directory",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "static-pending-state",
      "path": "/var/lib/powerforge/site-pending",
      "kind": "directory",
      "owner": "root",
      "group": "root",
      "mode": "700"
    },
    {
      "id": "backup-user-home",
      "path": "/var/lib/powerforge-codeglyphx-backup",
      "kind": "directory",
      "owner": "powerforge-codeglyphx-backup",
      "group": "powerforge-codeglyphx-backup",
      "mode": "700"
    },
    {
      "id": "backup-user-ssh",
      "path": "/var/lib/powerforge-codeglyphx-backup/.ssh",
      "kind": "directory",
      "owner": "powerforge-codeglyphx-backup",
      "group": "powerforge-codeglyphx-backup",
      "mode": "700"
    },
    {
      "id": "backup-user-authorized-keys",
      "path": "/var/lib/powerforge-codeglyphx-backup/.ssh/authorized_keys",
      "source": "/srv/evotec/CodeGlyphX/deploy/linux/powerforge-codeglyphx-backup-authorized_keys",
      "kind": "file",
      "owner": "powerforge-codeglyphx-backup",
      "group": "powerforge-codeglyphx-backup",
      "mode": "600"
    },
    {
      "id": "static-deployment-runtime",
      "path": "/usr/local/sbin/powerforge-site-deploy",
      "source": "/srv/evotec/PSPublishModule/Deployment/Linux/powerforge-site-deploy.sh",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "static-reconcile-runtime",
      "path": "/usr/local/sbin/powerforge-site-reconcile",
      "source": "/srv/evotec/PSPublishModule/Deployment/Linux/powerforge-site-reconcile.sh",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "encrypted-capture-runtime",
      "path": "/usr/local/sbin/powerforge-server-encrypted-capture",
      "source": "/srv/evotec/PSPublishModule/Deployment/Linux/powerforge-server-encrypted-capture.sh",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "apache-site-enable-runtime",
      "path": "/usr/local/sbin/powerforge-apache-site-enable",
      "source": "/srv/evotec/PSPublishModule/Deployment/Linux/powerforge-apache-site-enable.sh",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "cloudflare-origin-sync-runtime",
      "path": "/usr/local/sbin/powerforge-cloudflare-origin-sync",
      "source": "/srv/evotec/PSPublishModule/Deployment/Linux/powerforge-cloudflare-origin-sync.sh",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "powerforge-config-root",
      "path": "/etc/powerforge",
      "kind": "directory",
      "owner": "root",
      "group": "root",
      "mode": "755"
    },
    {
      "id": "powerforge-site-config-directory",
      "path": "/etc/powerforge/sites",
      "kind": "directory",
      "owner": "root",
      "group": "root",
      "mode": "750"
    },
    {
      "id": "cloudflare-origin-apache-config",
      "path": "/etc/apache2/conf-available/powerforge-cloudflare-origin.conf",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "644"
    },
    {
      "id": "static-deploy-config",
      "path": "/etc/powerforge/sites/codeglyphx.com.env",
      "source": "/srv/evotec/CodeGlyphX/deploy/linux/codeglyphx.com.env",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "640"
    },
    {
      "id": "deployment-sudoers",
      "path": "/etc/sudoers.d/powerforge-codeglyphx",
      "source": "/srv/evotec/CodeGlyphX/deploy/linux/powerforge-codeglyphx.sudoers",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "440",
      "validation": "sudoers"
    },
    {
      "id": "backup-sudoers",
      "path": "/etc/sudoers.d/powerforge-codeglyphx-backup",
      "source": "/srv/evotec/CodeGlyphXRecovery/deploy/linux/powerforge-codeglyphx-backup.sudoers",
      "kind": "file",
      "owner": "root",
      "group": "root",
      "mode": "440",
      "validation": "sudoers"
    }
  ],
  "apache": {
    "service": "apache2",
    "modules": [
      "headers",
      "remoteip",
      "rewrite",
      "setenvif",
      "ssl"
    ],
    "sites": [
      {
        "source": "/srv/evotec/CodeGlyphX/Website/deploy/apache.conf",
        "target": "/etc/apache2/sites-available/codeglyphx-com.conf",
        "required": true
      },
      {
        "source": "/srv/evotec/CodeGlyphX/Website/deploy/apache-ssl.conf",
        "target": "/etc/apache2/sites-available/codeglyphx-com-le-ssl.conf",
        "required": true
      }
    ],
    "validateCommand": "sudo -n apachectl configtest"
  },
  "firewall": {
    "provider": "ufw",
    "defaultIncoming": "deny",
    "defaultOutgoing": "allow",
    "sshPorts": [
      22222
    ],
    "webOriginPolicy": "cloudflare-only",
    "syncCommand": "/usr/local/sbin/powerforge-cloudflare-origin-sync"
  },
  "certificates": [
    {
      "name": "codeglyphx.com",
      "domains": [
        "codeglyphx.com",
        "www.codeglyphx.com"
      ],
      "authenticator": "apache",
      "renewalConfigPath": "/etc/letsencrypt/renewal/codeglyphx.com.conf",
      "dryRunCommand": "certbot renew --dry-run --cert-name codeglyphx.com --non-interactive --agree-tos --no-random-sleep-on-renew",
      "secretRefs": [
        "letsencrypt-codeglyphx-private-keys"
      ]
    }
  ],
  "systemd": {
    "services": [
      {
        "name": "powerforge-cloudflare-origin-sync.service",
        "source": "/srv/evotec/PSPublishModule/Deployment/Linux/systemd/powerforge-cloudflare-origin-sync.service",
        "target": "/etc/systemd/system/powerforge-cloudflare-origin-sync.service",
        "enabled": false,
        "required": true
      },
      {
        "name": "powerforge-site-reconcile.service",
        "source": "/srv/evotec/PSPublishModule/Deployment/Linux/systemd/powerforge-site-reconcile.service",
        "target": "/etc/systemd/system/powerforge-site-reconcile.service",
        "enabled": false,
        "required": true
      }
    ],
    "timers": [
      {
        "name": "powerforge-cloudflare-origin-sync.timer",
        "source": "/srv/evotec/PSPublishModule/Deployment/Linux/systemd/powerforge-cloudflare-origin-sync.timer",
        "target": "/etc/systemd/system/powerforge-cloudflare-origin-sync.timer",
        "enabled": true,
        "required": true
      },
      {
        "name": "powerforge-site-reconcile.timer",
        "source": "/srv/evotec/PSPublishModule/Deployment/Linux/systemd/powerforge-site-reconcile.timer",
        "target": "/etc/systemd/system/powerforge-site-reconcile.timer",
        "enabled": true,
        "required": true
      }
    ]
  },
  "secrets": [
    {
      "id": "letsencrypt-codeglyphx-private-keys",
      "path": "/etc/letsencrypt/archive/codeglyphx.com",
      "requiredFor": [
        "certificate-continuity"
      ],
      "requiredDuringBootstrap": false,
      "capture": "encrypted",
      "restoreMode": "directory"
    },
    {
      "id": "letsencrypt-acme-account",
      "path": "/etc/letsencrypt/accounts",
      "requiredFor": [
        "certificate-renewal"
      ],
      "requiredDuringBootstrap": false,
      "capture": "encrypted",
      "restoreMode": "directory"
    }
  ],
  "capture": {
    "plainFiles": [
      {
        "target": "/etc/apache2/sites-available/codeglyphx-com.conf",
        "required": true
      },
      {
        "target": "/etc/apache2/sites-available/codeglyphx-com-le-ssl.conf",
        "required": true
      },
      {
        "target": "/etc/apache2/conf-available/powerforge-cloudflare-origin.conf",
        "required": true
      },
      {
        "target": "/etc/systemd/system/powerforge-cloudflare-origin-sync.service",
        "required": true
      },
      {
        "target": "/etc/systemd/system/powerforge-cloudflare-origin-sync.timer",
        "required": true
      },
      {
        "target": "/etc/systemd/system/powerforge-site-reconcile.service",
        "required": true
      },
      {
        "target": "/etc/systemd/system/powerforge-site-reconcile.timer",
        "required": true
      },
      {
        "target": "/etc/powerforge/sites/codeglyphx.com.env",
        "required": true
      },
      {
        "target": "/etc/sudoers.d/powerforge-codeglyphx",
        "required": true
      },
      {
        "target": "/etc/sudoers.d/powerforge-codeglyphx-backup",
        "required": true
      },
      {
        "target": "/etc/letsencrypt/renewal/codeglyphx.com.conf",
        "required": true
      },
      {
        "target": "/etc/letsencrypt/options-ssl-apache.conf",
        "required": true
      }
    ],
    "encryptedFiles": [
      {
        "target": "/etc/letsencrypt/accounts",
        "required": true,
        "sensitive": true
      },
      {
        "target": "/etc/letsencrypt/archive/codeglyphx.com",
        "required": true,
        "sensitive": true
      },
      {
        "target": "/etc/letsencrypt/live/codeglyphx.com",
        "required": true,
        "sensitive": true
      }
    ],
    "commands": [
      {
        "id": "os-release",
        "command": "cat /etc/os-release",
        "required": true
      },
      {
        "id": "packages",
        "command": "dpkg-query -W -f='${binary:Package}\\t${Version}\\n'",
        "required": true
      },
      {
        "id": "apache-vhosts",
        "command": "sudo -n apachectl -S",
        "required": true
      },
      {
        "id": "release-link",
        "command": "readlink -f /var/www/codeglyphx/com/current",
        "required": true
      },
      {
        "id": "static-source-ref",
        "command": "jq -er '.sourceSha | select(type == \"string\" and test(\"^([0-9a-fA-F]{40}|[0-9a-fA-F]{64})$\"))' /var/www/codeglyphx/com/current/_powerforge/deployment.json",
        "required": true
      }
    ],
    "exclude": [
      "/var/www/codeglyphx/com/releases",
      "/srv/evotec/CodeGlyphX/Website/_site",
      "/srv/evotec/CodeGlyphX/Website/_reports",
      "/srv/evotec/CodeGlyphX/Website/_temp"
    ]
  },
  "deploy": {
    "commands": [
      {
        "id": "reload-systemd",
        "command": "systemctl daemon-reload",
        "required": true
      },
      {
        "id": "sync-cloudflare-origin",
        "command": "/usr/local/sbin/powerforge-cloudflare-origin-sync",
        "required": true
      },
      {
        "id": "enable-cloudflare-origin-sync",
        "command": "systemctl enable --now powerforge-cloudflare-origin-sync.timer",
        "required": true
      },
      {
        "id": "enable-static-deployment-reconciler",
        "command": "systemctl enable --now powerforge-site-reconcile.timer",
        "required": true
      },
      {
        "id": "enable-apache-site",
        "command": "/usr/local/sbin/powerforge-apache-site-enable --http-site codeglyphx-com.conf --https-site codeglyphx-com-le-ssl.conf --certificate-name codeglyphx.com",
        "required": true
      }
    ]
  },
  "verify": {
    "commands": [
      {
        "id": "apache-config",
        "command": "sudo -n apachectl configtest",
        "required": true
      },
      {
        "id": "cloudflare-origin-trust",
        "command": "test -s /var/lib/powerforge/cloudflare-origin/cidrs.txt && grep -Fq 'RemoteIPHeader CF-Connecting-IP' /etc/apache2/conf-enabled/powerforge-cloudflare-origin.conf && grep -Fq 'RemoteIPTrustedProxy ' /etc/apache2/conf-enabled/powerforge-cloudflare-origin.conf && systemctl is-enabled --quiet powerforge-cloudflare-origin-sync.timer",
        "required": true
      },
      {
        "id": "static-deployment-reconciler",
        "command": "test -x /usr/local/sbin/powerforge-site-reconcile && systemctl is-enabled --quiet powerforge-site-reconcile.timer && systemctl is-active --quiet powerforge-site-reconcile.timer",
        "required": true
      },
      {
        "id": "deployment-account",
        "command": "id -u powerforge-codeglyphx >/dev/null && sudo -n test -s /home/powerforge-codeglyphx/.ssh/authorized_keys && test \"$(sudo -n stat -c '%U:%G %a' /home/powerforge-codeglyphx/.ssh/authorized_keys)\" = 'powerforge-codeglyphx:powerforge-codeglyphx 600' && sudo -n visudo -cf /etc/sudoers.d/powerforge-codeglyphx",
        "required": true
      },
      {
        "id": "backup-account",
        "command": "id -u powerforge-codeglyphx-backup >/dev/null && sudo -n test -s /var/lib/powerforge-codeglyphx-backup/.ssh/authorized_keys && test \"$(sudo -n stat -c '%U:%G %a' /var/lib/powerforge-codeglyphx-backup/.ssh/authorized_keys)\" = 'powerforge-codeglyphx-backup:powerforge-codeglyphx-backup 600' && sudo -n visudo -cf /etc/sudoers.d/powerforge-codeglyphx-backup",
        "required": true
      },
      {
        "id": "repository-identity",
        "command": "git ls-remote https://github.com/EvotecIT/CodeGlyphX.git HEAD >/dev/null",
        "required": true
      },
      {
        "id": "static-provenance",
        "command": "test -s /var/www/codeglyphx/com/current/_powerforge/deployment.json",
        "required": true
      },
      {
        "id": "certbot-codeglyphx-dry-run",
        "command": "sudo -n certbot renew --dry-run --cert-name codeglyphx.com --non-interactive --agree-tos --no-random-sleep-on-renew",
        "required": true
      }
    ],
    "urls": [
      {
        "url": "https://codeglyphx.com/",
        "expectedStatus": 200,
        "via": "cloudflare"
      }
    ]
  },
  "backupTarget": {
    "type": "github",
    "repository": "EvotecIT/Evotec.ServerBackups",
    "branch": "main",
    "path": "ovh/codeglyphx",
    "encryption": "age",
    "recipient": "age1v4aw3yj7l4u9t5436ppy8hgem46lfy7wte9ww9ehfkhcwzldx4psd94wk6",
    "recipientEnv": "POWERFORGE_BACKUP_AGE_RECIPIENT",
    "retention": {
      "keepLatestInTree": 24
    }
  },
  "notes": [
    "CodeGlyphX is a public repository and fresh recovery uses anonymous HTTPS clones; no repository private key is required.",
    "Deployment and encrypted recovery capture use separate least-privilege SSH accounts and protected-environment private keys.",
    "Cloudflare cache purge credentials are transferred only for one deployment and are not persistent host recovery state.",
    "Deferred deployment state is root-only, short-lived, and intentionally excluded from recovery capture.",
    "Recovery rebuilds the excluded static release artifact through the protected deployment workflow before post-deploy verification checks exact provenance.",
    "Generated website output and timestamped releases are rebuildable and intentionally excluded from backup state."
  ]
}
